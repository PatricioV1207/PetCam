# PetCam environment configuration
# Copy to /opt/petcam/.env and adjust values.

DEVICE=/dev/video0

# V4L2 input format used by FFmpeg.
# Common values: mjpeg, yuyv422
# To find what your webcam supports, run:
#   v4l2-ctl -d /dev/video0 --list-formats-ext
# If mjpeg is not available, change this to yuyv422.
INPUT_FORMAT=mjpeg

# Recommended settings: 720p20 at 1 Mbps for reliable stability.
# Optional lower-quality mode (less CPU):
#   RESOLUTION=854x480
#   FRAMERATE=20
#   BITRATE=800k
RESOLUTION=1280x720
FRAMERATE=20
BITRATE=1M
PRESET=veryfast

MEDIAMTX_HOST=localhost
MEDIAMTX_PORT=8554
STREAM_PATH=cam

# FastAPI backend
API_HOST=0.0.0.0
API_PORT=8000
RECORDINGS_DIR=/opt/petcam/data/recordings
LIVE_HLS_URL=http://localhost:8888/cam/index.m3u8

# Playback remux cache
PLAYBACK_CACHE_DIR=/opt/petcam/data/playback-cache
PLAYBACK_REMUX_ENABLED=true
